#! /usr/bin/env bash
# use nix direnv to make evaluation faster
if ! has nix_direnv_version || ! nix_direnv_version 3.0.5; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.5/direnvrc" "sha256-RuwIS+QKFj/T9M2TFXScjBsLR6V3A17YVoEW/Q6AZ1w=" &>/dev/null
fi

use flake . --accept-flake-config

echo "Direnv loaded"
LAST_MODIFIED=$(stat flake.lock | grep "Modify" | awk '{print $2}')
LAST_MODIFIED_DAY=$(echo "$LAST_MODIFIED" | awk -F - '{print $3}')
LAST_MODIFIED_MONTH=$(echo "$LAST_MODIFIED" | awk -F - '{print $2}')
LAST_MODIFIED_YEAR=$(echo "$LAST_MODIFIED" | awk -F - '{print $1}')
CURRENT_DATE=$(date +%F)
CURRENT_DAY="10#$(echo "$CURRENT_DATE" | awk -F - '{print $3}')"
CURRENT_MONTH="10#$(echo "$CURRENT_DATE" | awk -F - '{print $2}')"
CURRENT_YEAR="10#$(echo "$CURRENT_DATE" | awk -F - '{print $1}')"
DIFFERENCE=$(((CURRENT_YEAR - LAST_MODIFIED_YEAR) * 365 + (CURRENT_MONTH - LAST_MODIFIED_MONTH) * 30 + (CURRENT_DAY - LAST_MODIFIED_DAY)))
echo "It's been $DIFFERENCE days since the flake.lock was updated"
if ! [ $DIFFERENCE -lt 14 ]; then
  printf '\033[0;31m'
  echo 'UPDATE THE FLAKE.LOCK FILE!!!'
  printf '\033[0m'
fi
